# Optional: copy to .env (see make configure). Loaded by python-dotenv in the CLI.
PYTHON_FRAMEWORK_APP_NAME=python-framework
PYTHON_FRAMEWORK_DEBUG=false

# OpenAI (prompt-example / structured extraction). Required for live LLM calls.
OPENAI_API_KEY=your_api_key_here
# Optional model override (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini
# In containers, plain logs are typical (compose.yaml sets this). Omit locally for Rich when stderr is a TTY.
# PYTHON_FRAMEWORK_PLAIN_LOG=1
